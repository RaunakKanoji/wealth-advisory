# Environment configuration (F007). Copy to `.env` for local development.
#
# Every EXPO_PUBLIC_* variable is inlined into the client bundle and is PUBLIC.
# Never put secrets, API keys, or privileged credentials in this file or in any
# EXPO_PUBLIC_* variable. Validation rules live in `src/config/env.ts`.

# One of: development | preview | production. Defaults to development.
EXPO_PUBLIC_APP_ENV=development

# Bank API gateway base URL. Optional in development (defaults to
# http://localhost:8080); required in preview and production (https only in
# production).
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Explicit mock mode: "true" routes integration-facing features to their
# deterministic development adapters. Must not be set in production.
EXPO_PUBLIC_USE_MOCK_DATA=true

# Development feature flag overrides ("true"/"false"). Honored in development
# and preview only; defaults live in `src/config/featureFlags.ts`.
# EXPO_PUBLIC_FLAG_COPILOT_VOICE=false
# EXPO_PUBLIC_FLAG_AVATAR_ANIMATION=false

# Clerk publishable key (pk_test_*/pk_live_*) — public by design and required.
# NEVER put sk_* secret keys or another privileged credential in an
# EXPO_PUBLIC_* variable.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
