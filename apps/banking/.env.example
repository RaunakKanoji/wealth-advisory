# Environment configuration (F007). Copy to `.env` for local development.
#
# Every EXPO_PUBLIC_* variable is inlined into the client bundle and is PUBLIC.
# Never put secrets, API keys, or privileged credentials in this file or in any
# EXPO_PUBLIC_* variable. Validation rules live in `src/config/env.ts`.

# One of: development | preview | production. Defaults to development.
EXPO_PUBLIC_APP_ENV=development

# Bank API gateway base URL. Optional in development (defaults to
# http://localhost:8080); required in preview and production (https only in
# production).
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Explicit mock mode: "true" routes integration-facing features to their
# deterministic development adapters. Must not be set in production.
EXPO_PUBLIC_USE_MOCK_DATA=true

# Development feature flag overrides ("true"/"false"). Honored in development
# and preview only; defaults live in `src/config/featureFlags.ts`.
# EXPO_PUBLIC_FLAG_COPILOT_VOICE=false
# EXPO_PUBLIC_FLAG_AVATAR_ANIMATION=false

# Authentication adapter. One of: mock | clerk | bank.
# - mock: deterministic development adapter (default in development).
#   Dev credentials: mobile 9876543210 / OTP 123456 (see
#   src/features/authentication/fixtures/authentication.fixtures.ts).
# - clerk: Clerk phone-code sign-in; requires the publishable key below.
# - bank: reserved for the approved IDBI provider (not implemented yet).
# Production rejects "mock" at startup. Logic lives in `src/config/env.ts`.
# EXPO_PUBLIC_AUTHENTICATION_MODE=mock

# Clerk publishable key (pk_test_*/pk_live_*) — public by design; required
# when EXPO_PUBLIC_AUTHENTICATION_MODE=clerk. NEVER put sk_* secret keys or
# any signing/OTP-provider secret in an EXPO_PUBLIC_* variable.
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# DEV-ONLY shell preview switch. Overrides the normal session bootstrap and
# boots straight into a chosen shell. One of: public | onboarding |
# authenticated. Unset = normal storage-backed bootstrap. Must not be set in
# production. Logic lives in `src/config/devSession.ts`.
# EXPO_PUBLIC_DEV_SESSION=authenticated
